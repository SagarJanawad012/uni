#!/bin/bash

echo "1. Displaying the contents of the file (cat):"

cat students.txt

echo

echo "2. Displaying the first 3 lines (head):"

head -n 3 students.txt

echo

echo "3. Displaying the last 2 lines (tail):"

tail -n 2 students.txt

echo

echo "4. Extracting and displaying only student names (cut):"

cut -f2 students.txt

echo

echo "5. Converting all student names to uppercase (tr):"

cut -f2 students.txt | tr '[:lower:]' '[:upper:]'

echo

echo "6. Sorting data based on marks in ascending order (sort):"

sort -k4-n students.txt

echo

echo "7. Displaying unique departments (cut, sort, uniq):"

cut -f3 students.txt | sort | uniq

echo

echo "8. Students who scored more than 80 marks (awk):"

awk -F'\t' '$4 > 80 {print $2}' students.txt

echo

echo "9. Replacing department name 'Computer' with 'CSE' (sed):" sed 's/Computer/CSE/g' students.txt

echo


