#!/bin/bash

echo "Step 1: Creating sample file example.txt"

touch example.txt

echo

echo "Step 2: Original permissions of the file:"

ls -l example.txt

echo

echo "Step 3: Changing permissions using symbolic mode (add execute for user)"

chmod u+x example.txt

echo "Permissions after symbolic mode change:"

ls -l example.txt

echo

echo "Step 4: Changing permissions using numeric mode (754)"

chmod 754 example.txt

echo "Permissions after numeric mode change:"

ls -l example.txt

echo

# Optional ownership change (requires sudo/root)

if [ "$(id-u)" -eq 0 ]; then

echo "Step 5: Changing ownership of the file"

chown nobody:nogroup example.txt

echo "Ownership after change:"

ls -l example.txt

else

echo "Step 5: Ownership change skipped (run as root to enable)" fi

echo

echo "Permission and ownership demonstration completed."



